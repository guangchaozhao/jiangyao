# Public OSS base URL, without trailing slash.
# Example: https://your-bucket.oss-cn-shenzhen.aliyuncs.com
VITE_OSS_BASE=

# Shared Doud public case-library base. The app reads manifest.json from here.
VITE_DOUD_PUBLIC_BASE=https://media.doudai.cc/avatar

# Local esports media source for npm run sync:oss.
JIANGYAO_ESPORTS_SOURCE_DIR=D:\AAACODE\Codetest\Doudtest\avatar\jiangyao-site-2026\esports

# Optional upload config for npm run sync:oss.
# If omitted locally, the script can fall back to the Doud backend .env on this machine.
JIANGYAO_OSS_BUCKET=jiangyao-site-2026
JIANGYAO_OSS_REGION=oss-cn-shenzhen
JIANGYAO_OSS_ACCESS_KEY_ID=
JIANGYAO_OSS_ACCESS_KEY_SECRET=
